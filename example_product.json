  "productInformations": [
    {
      "url": "https://www.rekikoski.fi/en/accommodation",
      "name": "Bed & Breakfast Rekikoski Accommodation",
      "language": "en",
      "webshopUrl": null,
      "description": "Our accommodation facilities are clean and smoke-free.\n\nIn the main building we have four twin rooms (2 people) and a large communal living room. There is also a small kitchen, communal sauna and shower facilities and 2 separate toilets. The accommodation in the main building is mainly used by groups.\n\nIn our terraced accommodation we have five twin rooms (2 people), and a larger suite in the end of the building. All rooms have their own shower, WC and mini kitchen and ten single room. All these rooms have own shower, WC, refrigerator and internet."
    }
